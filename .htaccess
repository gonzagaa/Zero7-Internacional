<IfModule mod_headers.c>
  # HTML: sempre revalidar (evita conteúdo desatualizado)
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # JSON de tradução: sem cache
  <FilesMatch "\.json$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>

  # Estáticos versionados (?v=): cache longo
  <FilesMatch "\.(css|js|png|jpe?g|gif|svg|webp|avif|woff2?|ttf)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>
